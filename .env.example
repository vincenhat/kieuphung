# ─── App auth ────────────────────────────────────────────────────────────
# Bootstrap passcode used until you set one via the Settings page.
# After you change the passcode in-app, this env var is no longer consulted.
APP_PASSCODE=changeme

# Secret used to sign session cookies. >= 32 random characters.
# Generate with: openssl rand -hex 32
SESSION_SECRET=put-a-long-random-string-here-at-least-32-chars

# ─── Firebase Admin (Firestore) ──────────────────────────────────────────
# Get these from the Firebase console:
#   Project Settings → Service accounts → Generate new private key
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
# Paste the entire private_key from the downloaded JSON, including
# "-----BEGIN PRIVATE KEY-----" lines. On Vercel you can keep the literal
# "\n" escape sequences; the app will convert them.
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"

# ─── AI providers (optional — add the ones you want to use) ──────────────
# Without any of these set, the AI-dependent tabs will show a "no AI key"
# notice but the rest of the app still works.

# Google Gemini (https://aistudio.google.com/apikey)
GOOGLE_API_KEY=
# Default model id used when the client doesn't pick one. Examples:
#   gemini-2.5-flash, gemini-2.5-flash-lite, groq-llama-3.3-70b, openrouter-deepseek-v3
GEMINI_MODEL=gemini-2.5-flash

# Groq (https://console.groq.com/keys)
GROQ_API_KEY=

# OpenRouter (https://openrouter.ai/keys)
OPENROUTER_API_KEY=

# ─── Firebase Web SDK (public, browser-exposed) ──────────────────────────
# Optional. Currently unused — only needed if you add client-side Firebase
# (Auth, client-side Firestore, Analytics, etc.) later.
# Get from Firebase console → Project Settings → Your apps → SDK setup & config.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
